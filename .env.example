# ==========================================================
# TDM Environment Variables — copy to .env and fill values
# ==========================================================

# --- OpenRouter (or any OpenAI-compatible provider) ---
OPENROUTER_API_KEY=

# --- Generation mode ---
# true = generate schemas locally from Core Entities / Tables, no LLM calls
# false = use API key and LLM agents
TDM_OFFLINE_MODE=false

# --- Optional: override default config file path ---
TDM_CONFIG_PATH=./config.yaml
